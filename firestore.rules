rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════════════════════════════════
    // Tips Collection - User kann nur eigene Tips schreiben
    // Joker-Limit wird durch Cloud Function validateJokerLimit erzwungen
    // ═══════════════════════════════════════════════════════════════════════
    match /tips/{tipId} {
      // Lesen: Alle authentifizierten User
      allow read: if request.auth != null;
      
      // Erstellen: Nur für eigenen User
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      
      // Aktualisieren: Nur eigene Tips + Cloud Functions (ohne auth)
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      
      // Löschen: Nur eigene Tips
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
    
    // ═══════════════════════════════════════════════════════════════════════
    // Users Collection
    // ═══════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Lesen: Alle authentifizierten User (für Rangliste etc.)
      allow read: if request.auth != null;
      
      // Schreiben: Nur eigenes Profil ODER Admin
      allow write: if request.auth != null 
        && (request.auth.uid == userId 
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true);
    }
    
    // ═══════════════════════════════════════════════════════════════════════
    // Matches Collection - Nur Admins können schreiben
    // ═══════════════════════════════════════════════════════════════════════
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }
    
    // ═══════════════════════════════════════════════════════════════════════
    // Teams Collection - Nur Admins können schreiben
    // ═══════════════════════════════════════════════════════════════════════
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }
  }
}
